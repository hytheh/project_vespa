@article{keller2020photonicfence,
  author  = {Keller, Matthew D. and Norton, Bryan J. and Farrar, David J. and
             Rutschman, Phil and Marvit, Maclen and Makagon, Arty},
  title   = {Optical tracking and laser-induced mortality of insects during
             flight},
  journal = {Scientific Reports},
  volume  = {10},
  number  = {1},
  pages   = {14795},
  year    = {2020},
  doi     = {10.1038/s41598-020-71824-y},
  url     = {https://doi.org/10.1038/s41598-020-71824-y},
  note    = {\textbf{La référence qui manquait au dimensionnement du tir.}
             \emph{Photonic Fence} (Intellectual Ventures) : le seul système
             publié qui neutralise au laser des insectes \emph{en vol}, avec
             courbes dose-réponse mesurées. Fonde \textbf{deux} des trois
             constantes de \texttt{Laser\_Optics\_v1.m} :
             (1)~\textbf{le choix du bleu} — les longueurs d'onde visibles
             exigent une exposition « significativement plus faible » que le
             proche infrarouge (LD90 $= 1{,}6$~J/cm$^2$ à 445~nm contre
             $12{,}9$~J/cm$^2$ à 1064~nm) ;
             (2)~\textbf{la durée d'impulsion} — 25~ms est identifiée comme
             la durée idéale pour minimiser la puissance requise, et le
             comportement de vol de la cible n'affecte pas la mortalité en
             deçà. Les 20~ms du projet tombent dans cette fenêtre.
             \textbf{En revanche, la fluence létale de 50~J/cm$^2$ retenue
             par le projet ne vient PAS de cet article} : les sujets testés
             sont des \emph{Anopheles}, deux ordres de grandeur plus légers
             qu'une ouvrière de \emph{V. velutina}. Voir l'avertissement du
             chapitre « Optique et sécurité laser ».},
  file    = {docs/references/articles/Keller2020_Optical_tracking_laser_mortality_insects_SciRep.pdf}
}

@article{keller2016mosquito,
  author  = {Keller, Matthew D. and Leahy, David J. and Norton, Bryan J. and
