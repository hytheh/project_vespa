@article{ruizcristi2020thermotolerance,
  author  = {Ruiz-Cristi, Ignacio and Berville, Laurence and
             Darrouzet, Eric},
  title   = {Characterizing thermal tolerance in the invasive yellow-legged
             hornet ({\emph{Vespa velutina nigrithorax}}): the first step
             toward a green control method},
  journal = {PLoS ONE},
  volume  = {15},
  number  = {10},
  pages   = {e0239742},
  year    = {2020},
  doi     = {10.1371/journal.pone.0239742},
  url     = {https://doi.org/10.1371/journal.pone.0239742},
  note    = {\textbf{Source de la donnée biologique manquante} : la limite
             thermique létale de l'espèce cible, mesurée sur
             \emph{V. velutina nigrithorax} elle-même (et non sur un
             modèle de substitution), tous sexes, castes et stades.
             C'est la \emph{température de fin} qu'un dimensionnement
             thermophysique doit atteindre — le point d'arrivée du calcul
             d'irradiance de \texttt{Laser\_Optics\_v1.m}.
             \textbf{Attention à ne pas surinterpréter} : les temps
             d'exposition de cet article (de 13~s à plusieurs minutes)
             relèvent d'un chauffage \emph{convectif du corps entier}
             (étuve, flux d'air humide). Ils ne se transposent pas
             directement à une impulsion laser localisée de 20~ms. L'article
             fournit le seuil, pas la dose.},
  file    = {docs/references/articles/RuizCristi2020_Thermal_tolerance_Vespa_velutina_PLoSONE.pdf}
}

@article{ono1995thermal,
  author  = {Ono, Masato and Igarashi, Takeshi and Ohno, Eishi and
             Sasaki, Masami},
  title   = {Unusual thermal defence by a honeybee against mass attack by
             hornets},
  journal = {Nature},
  volume  = {377},
  number  = {6547},
  pages   = {334--336},
  year    = {1995},
  doi     = {10.1038/377334a0},
  url     = {https://doi.org/10.1038/377334a0},
  note    = {Référence historique corroborant l'ordre de grandeur
             précédent : l'abeille japonaise tue le frelon en l'étouffant
             dans une boule à $\approx 47^\circ$C, létale pour le frelon
             et non pour elle. Établit l'\emph{écart} de tolérance
             thermique (frelon $\approx 45^\circ$C, abeille
             $\approx 50^\circ$C). Utile ici pour une seule raison :
             la neutralisation thermique du frelon est un mécanisme
             \textbf{attesté dans la nature}, pas une extrapolation de
             laboratoire.}
}


