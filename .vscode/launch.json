{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch Vision Node",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/software/builds/vision_node/vespa_vision",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/software/vision_node",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake: Build"
        }
    ]
}